---
import PageHeader from "../components/PageHeader.astro";
import { AppConfig } from "../config/AppConfig";
import Main from "../layouts/Main.astro";
import localThoughts from "../content/thoughts.json";
import { format } from "date-fns";

const THOUGHTS_URL = "https://cdn.jsdelivr.net/gh/dhanushk-offl/is-data@master/thoughts.json";

let thoughts = localThoughts;

try {
  const response = await fetch(THOUGHTS_URL);
  if (response.ok) {
    const remoteThoughts = await response.json();
    if (Array.isArray(remoteThoughts)) {
      thoughts = remoteThoughts;
    }
  }
} catch {
  // Fall back to local content when remote fetch is unavailable.
}
---

<Main
  meta={{
    title: `Thoughts | ${AppConfig.title}`,
    description: "Curated personal thoughts and professional insights.",
  }}
>
  <div class="pb-8 pt-2">
    <PageHeader 
      title="Thoughts" 
      emoji="🧠" 
      description="Curated personal thoughts and professional insights."
    />

    <div class="mt-12 space-y-12">
      {thoughts.map((item, index) => (
        <div
          class="group relative space-y-4 p-6 -mx-6 rounded-xl hover:bg-zinc-900/50 border border-transparent hover:border-zinc-800 transition-all duration-300"
          data-thought-card
          data-thought={item.thought}
          data-category={item.category}
          data-date={format(new Date(item.date), 'MMM dd, yyyy')}
          data-index={String(index + 1).padStart(2, '0')}
        >
          <div class="flex items-center justify-between">
            <span class="font-mono text-xxs uppercase tracking-[0.2em] text-emerald-500">
              [{String(index + 1).padStart(2, '0')}] {item.category}
            </span>
            <span class="font-mono text-[10px] uppercase tracking-widest text-zinc-500 opacity-50">
              {format(new Date(item.date), 'MMM dd, yyyy')}
            </span>
          </div>
          <p class="text-base sm:text-lg text-zinc-200 leading-relaxed font-mono">
            {item.thought}
          </p>
          <div class="pt-2 flex flex-wrap items-center gap-2 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">
            <button
              class="thought-share-toggle size-8 rounded-md border border-zinc-800 bg-zinc-900/80 text-zinc-200 hover:bg-zinc-800 transition-colors inline-flex items-center justify-center"
              data-action="toggle-share"
              type="button"
              aria-label="Share"
              title="Share"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="18" cy="5" r="3"></circle>
                <circle cx="6" cy="12" r="3"></circle>
                <circle cx="18" cy="19" r="3"></circle>
                <line x1="8.6" y1="13.5" x2="15.4" y2="17.5"></line>
                <line x1="15.4" y1="6.5" x2="8.6" y2="10.5"></line>
              </svg>
            </button>
            <div class="hidden items-center gap-2" data-share-menu>
              <button
                class="thought-action size-8 rounded-md border border-zinc-800 bg-zinc-900/80 text-zinc-200 hover:bg-zinc-800 transition-colors inline-flex items-center justify-center"
                data-action="download-image"
                type="button"
                aria-label="Download image"
                title="Download image"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="7 10 12 15 17 10"></polyline>
                  <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
              </button>
              <button
                class="thought-action size-8 rounded-md border border-zinc-800 bg-zinc-900/80 text-zinc-200 hover:bg-zinc-800 transition-colors inline-flex items-center justify-center text-[11px] font-semibold"
                data-action="share-x"
                type="button"
                aria-label="Share on X"
                title="Share on X"
              >
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
                  <path d="M18.244 2h3.308l-7.227 8.26L23 22h-6.735l-5.278-6.89L4.96 22H1.65l7.73-8.835L1 2h6.907l4.77 6.232L18.244 2Zm-1.161 18h1.833L6.91 3.895H4.943L17.083 20Z"></path>
                </svg>
              </button>
              <button
                class="thought-action size-8 rounded-md border border-zinc-800 bg-zinc-900/80 text-zinc-200 hover:bg-zinc-800 transition-colors inline-flex items-center justify-center text-[11px] font-semibold"
                data-action="share-reddit"
                type="button"
                aria-label="Share on Reddit"
                title="Share on Reddit"
              >
                <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true">
                  <circle cx="12" cy="13.5" r="5.5"></circle>
                  <circle cx="9.8" cy="13.2" r="0.8" fill="#0b0b0b"></circle>
                  <circle cx="14.2" cy="13.2" r="0.8" fill="#0b0b0b"></circle>
                  <path d="M9.4 15.7c.7.5 1.6.8 2.6.8s1.9-.3 2.6-.8" stroke="#0b0b0b" stroke-width="1.2" fill="none" stroke-linecap="round"></path>
                  <circle cx="18.4" cy="9.8" r="1.4"></circle>
                  <path d="M13.8 8.2l1.1-3.2 2.3.5" stroke="currentColor" stroke-width="1.3" fill="none" stroke-linecap="round"></path>
                </svg>
              </button>
              <button
                class="thought-action size-8 rounded-md border border-zinc-800 bg-zinc-900/80 text-zinc-200 hover:bg-zinc-800 transition-colors inline-flex items-center justify-center text-[10px] font-semibold"
                data-action="share-linkedin"
                type="button"
                aria-label="Share on LinkedIn"
                title="Share on LinkedIn"
              >
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
                  <path d="M4.98 3.5A2.48 2.48 0 0 0 2.5 5.98c0 1.36 1.1 2.47 2.48 2.47s2.48-1.1 2.48-2.47A2.48 2.48 0 0 0 4.98 3.5ZM2.9 9.5h4.2V21H2.9V9.5ZM9.4 9.5h4.02v1.57h.06c.56-1.05 1.92-2.16 3.95-2.16 4.22 0 5 2.78 5 6.39V21h-4.2v-4.96c0-1.18-.02-2.7-1.65-2.7-1.65 0-1.9 1.29-1.9 2.62V21H9.4V9.5Z"></path>
                </svg>
              </button>
            </div>
            <span class="size-1 rounded-full bg-emerald-500 ml-1"></span>
            <span class="text-[9px] font-mono uppercase tracking-[0.3em] text-zinc-600" data-share-status>Secure_Transmission_Logged</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</Main>

<script>
  type ThoughtCard = {
    thought: string;
    category: string;
    date: string;
    index: string;
  };
  const MIN_IMAGE_BYTES = 250 * 1024;
  const MAX_IMAGE_BYTES = 500 * 1024;

  function wrapText(ctx: CanvasRenderingContext2D, text: string, maxWidth: number): string[] {
    const words = text.split(/\s+/);
    const lines: string[] = [];
    let current = "";
    for (const word of words) {
      const candidate = current ? `${current} ${word}` : word;
      if (ctx.measureText(candidate).width <= maxWidth) {
        current = candidate;
      } else {
        if (current) lines.push(current);
        current = word;
      }
    }
    if (current) lines.push(current);
    return lines;
  }

  const CANONICAL_THOUGHTS_URL = "dhanu.letretro.com/thoughts";

  async function renderThoughtImage(data: ThoughtCard): Promise<Blob> {
    const canvas = document.createElement("canvas");
    canvas.width = 1600;
    canvas.height = 900;
    const ctx = canvas.getContext("2d");
    if (!ctx) throw new Error("2D canvas is not available");

    const gradient = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
    gradient.addColorStop(0, "#05070b");
    gradient.addColorStop(0.55, "#0f172a");
    gradient.addColorStop(1, "#111827");
    ctx.fillStyle = gradient;
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    const radial = ctx.createRadialGradient(
      canvas.width * 0.85,
      canvas.height * 0.08,
      0,
      canvas.width * 0.85,
      canvas.height * 0.08,
      canvas.width * 0.85
    );
    radial.addColorStop(0, "rgba(16, 185, 129, 0.18)");
    radial.addColorStop(1, "rgba(16, 185, 129, 0)");
    ctx.fillStyle = radial;
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    ctx.strokeStyle = "rgba(16, 185, 129, 0.24)";
    ctx.lineWidth = 3;
    ctx.strokeRect(52, 52, canvas.width - 104, canvas.height - 104);

    ctx.strokeStyle = "rgba(16, 185, 129, 0.14)";
    ctx.lineWidth = 1;
    for (let x = 120; x < canvas.width; x += 120) {
      ctx.beginPath();
      ctx.moveTo(x, 110);
      ctx.lineTo(x, canvas.height - 110);
      ctx.stroke();
    }

    ctx.fillStyle = "#10b981";
    ctx.font = "700 30px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
    ctx.fillText(`[${data.index}] ${data.category.toUpperCase()}`, 112, 148);

    ctx.fillStyle = "rgba(229, 231, 235, 0.8)";
    ctx.font = "600 24px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
    ctx.fillText(data.date.toUpperCase(), canvas.width - 430, 148);

    ctx.fillStyle = "#f3f4f6";
    ctx.font = "600 56px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
    const lines = wrapText(ctx, data.thought, canvas.width - 250);
    const maxLines = 8;
    const clipped = lines.slice(0, maxLines);
    if (lines.length > maxLines) {
      clipped[maxLines - 1] = `${clipped[maxLines - 1].replace(/[. ]+$/, "")}...`;
    }

    const lineHeight = 74;
    let y = 264;
    ctx.fillStyle = "rgba(16, 185, 129, 0.8)";
    ctx.font = "900 98px Georgia, serif";
    ctx.fillText('"', 94, y - 28);
    ctx.fillStyle = "#f3f4f6";
    ctx.font = "600 56px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
    clipped.forEach((line) => {
      ctx.fillText(line, 152, y);
      y += lineHeight;
    });

    ctx.fillStyle = "rgba(16, 185, 129, 0.9)";
    ctx.fillRect(112, canvas.height - 144, 390, 3);
    ctx.fillStyle = "rgba(229, 231, 235, 0.8)";
    ctx.font = "600 24px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
    ctx.fillText(CANONICAL_THOUGHTS_URL, 112, canvas.height - 102);

    ctx.fillStyle = "rgba(255,255,255,0.58)";
    ctx.font = "600 22px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
    ctx.textAlign = "right";
    ctx.fillText("Dhanu's Thoughts", canvas.width - 112, canvas.height - 102);
    ctx.textAlign = "left";

    let selectedBlob: Blob | null = null;
    let bestBlob: Blob | null = null;
    for (const quality of [0.92, 0.88, 0.84, 0.8, 0.76, 0.72, 0.68]) {
      const blob = await new Promise<Blob | null>((resolve) => {
        canvas.toBlob((out) => resolve(out), "image/jpeg", quality);
      });
      if (!blob) continue;
      if (!bestBlob || Math.abs(blob.size - 360 * 1024) < Math.abs(bestBlob.size - 360 * 1024)) {
        bestBlob = blob;
      }
      if (blob.size >= MIN_IMAGE_BYTES && blob.size <= MAX_IMAGE_BYTES) {
        selectedBlob = blob;
        break;
      }
    }
    if (selectedBlob) return selectedBlob;
    if (bestBlob) return bestBlob;
    return new Promise((resolve, reject) => {
      canvas.toBlob((blob) => {
        if (!blob) {
          reject(new Error("Failed to generate image"));
          return;
        }
        resolve(blob);
      }, "image/jpeg", 0.82);
    });
  }

  function downloadBlob(blob: Blob, filename: string): void {
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
  }

  async function copyImageToClipboard(blob: Blob): Promise<boolean> {
    if (!("clipboard" in navigator) || typeof ClipboardItem === "undefined") return false;
    try {
      await navigator.clipboard.write([new ClipboardItem({ [blob.type]: blob })]);
      return true;
    } catch {
      return false;
    }
  }

  function setStatus(cardEl: HTMLElement, message: string): void {
    const statusEl = cardEl.querySelector<HTMLElement>("[data-share-status]");
    if (statusEl) statusEl.textContent = message;
  }

  async function handleCardAction(cardEl: HTMLElement, action: string): Promise<void> {
    const data: ThoughtCard = {
      thought: cardEl.dataset.thought || "",
      category: cardEl.dataset.category || "Thought",
      date: cardEl.dataset.date || "",
      index: cardEl.dataset.index || "00",
    };
    const thoughtSlug = data.thought.toLowerCase().replace(/[^a-z0-9]+/g, "-").slice(0, 30).replace(/(^-|-$)/g, "");
    const filename = `thought-${data.index}-${thoughtSlug || "note"}.jpg`;
    const pageUrl = CANONICAL_THOUGHTS_URL;
    const shortText = `${data.thought.slice(0, 180)}${data.thought.length > 180 ? "..." : ""}`;
    const shareText = `${shortText} | ${data.category}`;

    setStatus(cardEl, "Generating_Image...");
    const blob = await renderThoughtImage(data);

    if (action === "download-image") {
      downloadBlob(blob, filename);
      setStatus(cardEl, "Image_Saved");
      return;
    }

    const shareUrls: Record<string, string> = {
      "share-x": `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(pageUrl)}`,
      "share-reddit": `https://www.reddit.com/submit?url=${encodeURIComponent(pageUrl)}&title=${encodeURIComponent(shareText)}`,
      "share-linkedin": `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`,
    };

    const copied = await copyImageToClipboard(blob);
    downloadBlob(blob, filename);
    setStatus(cardEl, copied ? "Opened_Share_And_Copied_Image" : "Opened_Share_And_Downloaded_Image");

    const target = shareUrls[action];
    if (target) window.open(target, "_blank", "noopener,noreferrer");
  }

  const thoughtCards = document.querySelectorAll<HTMLElement>("[data-thought-card]");

  function closeShareMenus(except?: HTMLElement): void {
    thoughtCards.forEach((card) => {
      if (except && card === except) return;
      const menu = card.querySelector<HTMLElement>("[data-share-menu]");
      if (!menu) return;
      menu.classList.add("hidden");
      menu.classList.remove("inline-flex");
    });
  }

  thoughtCards.forEach((cardEl) => {
    const shareToggle = cardEl.querySelector<HTMLButtonElement>(".thought-share-toggle");
    if (shareToggle) {
      shareToggle.addEventListener("click", () => {
        const menu = cardEl.querySelector<HTMLElement>("[data-share-menu]");
        if (!menu) return;
        const opening = menu.classList.contains("hidden");
        closeShareMenus(cardEl);
        if (opening) {
          menu.classList.remove("hidden");
          menu.classList.add("inline-flex");
        } else {
          menu.classList.add("hidden");
          menu.classList.remove("inline-flex");
        }
      });
    }

    const actions = cardEl.querySelectorAll<HTMLButtonElement>(".thought-action");
    actions.forEach((button) => {
      button.addEventListener("click", async () => {
        const action = button.dataset.action;
        if (!action) return;
        button.disabled = true;
        try {
          await handleCardAction(cardEl, action);
        } catch {
          setStatus(cardEl, "Share_Failed_Try_Again");
        } finally {
          button.disabled = false;
        }
      });
    });
  });

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement;
    if (target.closest("[data-share-menu]") || target.closest(".thought-share-toggle")) return;
    closeShareMenus();
  });
</script>
